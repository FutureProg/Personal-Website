{
  "name": "profile-page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter client run dev",
    "build:client": "pnpm --filter client run build",
    "build:backend": "pnpm --filter backend run build",
    "build": "pnpm run build:client && pnpm run build:backend",
    "preview": "pnpm --filter client run preview",
    "storybook": "pnpm --filter client run storybook",
    "build-storybook": "pnpm --filter client run build-storybook",
    "test:unit": "pnpm --filter client run test:unit",
    "test:unit:watch": "pnpm --filter client run test:unit:watch",
    "chromatic": "pnpm --filter client run chromatic",
    "design-sync:build": "node .ds-sync/package-build.mjs --config .design-sync/config.json --node-modules src/client/node_modules --entry src/client/components/index.ts --out ds-bundle",
    "design-sync:resync": "node .ds-sync/resync.mjs --config .design-sync/config.json --node-modules src/client/node_modules --entry src/client/components/index.ts --out ds-bundle"
  }
}
